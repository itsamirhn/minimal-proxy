{
  "inbounds": [
    {
      "port": 1080,
      "listen": "0.0.0.0",
      "protocol": "socks",
      "settings": {
        "udp": true
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "VLESS_ADDRESS_PLACEHOLDER",
            "port": VLESS_PORT_PLACEHOLDER,
            "users": [
              {
                "id": "VLESS_UUID_PLACEHOLDER",
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "tcp"
      }
    }
  ]
}
